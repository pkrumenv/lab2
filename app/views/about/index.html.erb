<div class="container mt-4">

  <h1 class="text-center mb-4">Personal Page</h1>

  <!-- Info personal -->
  <div class="card mb-4">
    <div class="card-body">
      <ul class="list-group list-group-flush">
        <li class="list-group-item"><strong>Name:</strong> Pablo Krumenaker Vigneaux</li>
        <li class="list-group-item"><strong>Major:</strong> Ingeniería Civil en Ciencias de la Computación</li>
        <li class="list-group-item"><strong>Year of Enrollment:</strong> 2024</li>
        <li class="list-group-item">
          <strong>Github:</strong> 
          <a href="https://github.com/pkrumenv" target="_blank">Visit profile</a>
        </li>
      </ul>
    </div>
  </div>

  <!-- About -->
  <div class="card mb-4">
    <div class="card-body">
      <h2>About me</h2>
      <p>
        "I'm 21 years old and I'm studying computer science because I really like computers, math and playing video games with my friends. If I weren't an engineering student I would be a carpenter. My favorite color is blue"
      </p>
    </div>
  </div>

  <!-- Skills -->
  <div class="card mb-4">
    <div class="card-body">
      <h2>Skills</h2>
      <table class="table table-striped table-bordered">
        <thead class="table-dark">
          <tr>
            <th>Skill</th>
            <th>Level</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Python</td>
            <td class="text-success fw-bold">Advanced</td>
          </tr>
          <tr>
            <td>JavaScript</td>
            <td class="text-warning fw-bold">Intermediate</td>
          </tr>
          <tr>
            <td>HTML/CSS</td>
            <td class="text-danger fw-bold">Basic</td>
          </tr>
          <tr>
            <td>SQL</td>
            <td class="text-warning fw-bold">Intermediate</td>
          </tr>
          <tr>
            <td>C/C++</td>
            <td class="text-success fw-bold">Advanced</td>
          </tr>
          <tr>
            <td>English</td>
            <td class="text-success fw-bold">Advanced</td>
          </tr>
          <tr>
            <td>Spanish</td>
            <td class="fw-bold">Native</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Notes -->
  <div class="card mb-4">
    <div class="card-body">
      <h2>Notes</h2>
      <div class="input-group mb-3">
        <input type="text" id="notesInput" class="form-control" placeholder="Write a note...">
        <button class="btn btn-primary" onclick="addText()">Add</button>
      </div>

      <ul id="list" class="list-group"></ul>
    </div>
  </div>

    <!-- Imagen -->
    <div class="text-center">
        <%= image_tag "me.jpeg", class: "img-fluid rounded", style: "max-width: 300px;", alt: "literally me" %>
    </div>

</div>

<script>
function addText() {
    const input = document.getElementById("notesInput");
    const texto = input.value.trim();

    if (texto === "") return;

    const lista = document.getElementById("list");

    const nuevoItem = document.createElement("li");
    nuevoItem.className = "list-group-item";
    nuevoItem.textContent = texto;

    lista.appendChild(nuevoItem);

    input.value = "";
}
</script>